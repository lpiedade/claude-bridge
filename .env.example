# Copy to .env and fill in. The launchd plist reads these via a wrapper script.

# --- Required ---
CLAUDE_BRIDGE_TG_TOKEN=123456:ABC-DEF-your-bot-token
CLAUDE_BRIDGE_ALLOWED_CHATS=111111111

# --- Working directory ---
# Default cwd for new sessions. Must be inside one of CLAUDE_BRIDGE_CWD_ROOTS.
CLAUDE_BRIDGE_CWD=~/EDF/Personal/Github
# Allowlist of roots /cd may switch into (comma-separated). Symlinks resolved before check.
CLAUDE_BRIDGE_CWD_ROOTS=~/EDF/Personal/Github,~/EDF/BlindBet

# --- Claude CLI behavior ---
# Valid: default, acceptEdits, plan, bypassPermissions, auto, dontAsk
CLAUDE_BRIDGE_PERMISSION_MODE=acceptEdits
# Per-message timeout (seconds)
CLAUDE_BRIDGE_TIMEOUT=600
# Default effort. One of: low, medium, high, xhigh, max. Per-chat override via /effort.
CLAUDE_BRIDGE_EFFORT=low
# Default model. One of: opus, sonnet, haiku. Per-chat override via /model.
CLAUDE_BRIDGE_MODEL=haiku

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL. Applies to bridge.log and conversation.log.
CLAUDE_BRIDGE_LOG_LEVEL=INFO

# --- Cost Alert agent (hourly launchd job) ---
COST_ALERT_ENABLED=true
COST_ALERT_THRESHOLD_USD=10
COST_ALERT_RECIPIENT=leoabrahao@gmail.com
COST_ALERT_INTERVAL_SECONDS=3600
